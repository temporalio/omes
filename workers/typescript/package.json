{
  "name": "omes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npm run proto-gen && tsc --build",
    "build.watch": "tsc --build --watch",
    "clean": "rm -rf node_modules lib dist dist-test build harness/api workerlib/kitchensink/protos/json-module.js workerlib/kitchensink/protos/root.d.ts",
    "proto-gen": "node ./protogen.js",
    "lint": "eslint .",
    "lint-ci": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test:harness": "npm run harness:build-test && node --test dist-test/harness/tests/app-registry.test.js dist-test/harness/tests/project.test.js dist-test/harness/tests/worker.test.js",
    "harness:build-test": "npm run proto-gen && tsc --project tsconfig.test.json",
    "typecheck": "tsc --noEmit"
  },
  "nodemonConfig": {
    "execMap": {
      "ts": "ts-node"
    },
    "ext": "ts",
    "watch": [
      "apps",
      "harness",
      "workerlib"
    ]
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@temporalio/activity": "^1.17.1",
    "@temporalio/client": "^1.17.1",
    "@temporalio/common": "^1.17.1",
    "@temporalio/worker": "^1.17.1",
    "@temporalio/workflow": "^1.17.1",
    "commander": "^11.1.0",
    "long": "^5.2.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@temporalio/testing": "^1.17.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^9.1.0",
    "nodemon": "^2.0.12",
    "prettier": "^3.1.1",
    "protobufjs": "7.5.1",
    "protobufjs-cli": "^1.0.0",
    "ts-node": "^10.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.10.0"
  }
}
