{
  "extends": "@tsconfig/node24/tsconfig.json",
  "version": "5.9.0",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowJs": true,
    "rootDir": ".",
    "outDir": "./lib"
  },
  "include": [
    "src/**/*.ts",
    "projects/**/*.ts",
    "src/protos/json-module.js",
    "src/protos/root.js"
  ],
  "exclude": [
    "projects/harness/tests"
  ]
}
